      },
      "title": "Total Site Consumed",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"fronius_daily\")\n  |> range(start: -2d)\n  |> filter(fn: (r) => r._measurement == \"energy_daily\")\n  |> filter(fn: (r) => r._field == \"pv_produced_wh\" or r._field == \"grid_consumed_wh\" or r._field == \"grid_exported_wh\")\n  |> pivot(rowKey: [\"_time\"], columnKey: [\"_field\"], valueColumn: \"_value\")\n  |> map(fn: (r) => ({_time: r._time, _value: r.pv_produced_wh + r.grid_consumed_wh - r.grid_exported_wh}))\n  |> set(key: \"_field\", value: \"site_consumed_wh\")\n  |> last()",
          "refId": "A"
        }
      ]
    },

