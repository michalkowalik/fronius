      "type": "gauge",
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"${bucket}\")\n  |> range(start: -5m)\n  |> filter(fn: (r) => r._measurement == \"fronius_powerflow\" and r._field == \"self_consumption_pct\")\n  |> last()",
