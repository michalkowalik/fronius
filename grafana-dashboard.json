              { "id": "color", "value": { "fixedColor": "#E02F44", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "e_produced_wh" },
            "properties": [
              { "id": "displayName", "value": "Total Exported (Wh)" },
              { "id": "color", "value": { "fixedColor": "#73BF69", "mode": "fixed" } }
            ]
          }
        ]
      },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 35 },
      "id": 22,
      "options": {
        "legend": { "calcs": ["last"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "title": "Meter — Cumulative Energy (Consumed vs Exported)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"${bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"fronius_meter\")\n  |> filter(fn: (r) => r._field == \"e_consumed_wh\" or r._field == \"e_produced_wh\")\n  |> aggregateWindow(every: v.windowPeriod, fn: last, createEmpty: false)\n  |> pivot(rowKey: [\"_time\"], columnKey: [\"_field\"], valueColumn: \"_value\")",
          "refId": "A"
        }
      ]
